# copy to .env and adjust

# logging filter
RUST_LOG=info

# gateway (data plane)
ROLTER_CONFIG=rolter.toml
ROLTER_HOST=0.0.0.0
ROLTER_PORT=4000

# control plane (management api + ui host)
ROLTER_CONTROL_HOST=0.0.0.0
ROLTER_CONTROL_PORT=4001
ROLTER_UI_DIR=ui/dist

# master key for envelope-encrypting provider secrets at rest (aes-256-gcm kek)
# generate with: openssl rand -hex 32
ROLTER_MASTER_KEY=

# upstream provider keys referenced by api_key_env in the config
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# datastores (used by the control plane and logging; not required for the gateway mvp)
DATABASE_URL=postgres://rolter:rolter@localhost:5432/rolter
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://localhost:8123
